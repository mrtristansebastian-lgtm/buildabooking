rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasStaffAccess(appId, userId) {
      return signedIn() &&
        request.auth.token.email != null &&
        firestore.exists(/databases/(default)/documents/artifacts/$(appId)/staffAccess/$(request.auth.token.email)/workspaces/$(userId)) &&
        firestore.get(/databases/(default)/documents/artifacts/$(appId)/staffAccess/$(request.auth.token.email)/workspaces/$(userId)).data.status == 'active';
    }

    match /artifacts/{appId}/users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) || hasStaffAccess(appId, userId);
    }
  }
}
