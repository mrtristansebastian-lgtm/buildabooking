rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasStaffAccess(appId, userId) {
      return signedIn() &&
        request.auth.token.email != null &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/staffAccess/$(request.auth.token.email)/workspaces/$(userId)) &&
        get(/databases/$(database)/documents/artifacts/$(appId)/staffAccess/$(request.auth.token.email)/workspaces/$(userId)).data.status == 'active';
    }

    function staffRole(appId, userId) {
      return get(/databases/$(database)/documents/artifacts/$(appId)/staffAccess/$(request.auth.token.email)/workspaces/$(userId)).data.role;
    }

    function canStaff(appId, userId) {
      return isOwner(userId) || hasStaffAccess(appId, userId);
    }

    function canAdmin(appId, userId) {
      return isOwner(userId) || (hasStaffAccess(appId, userId) && staffRole(appId, userId) == 'admin');
    }

    function isThreadParticipant(appId, threadData) {
      return signedIn() &&
        threadData.ownerId is string &&
        (
          canStaff(appId, threadData.ownerId) ||
          (request.auth.token.email != null && threadData.clientEmail == request.auth.token.email)
        );
    }

    function canAccessThread(appId, threadId) {
      return exists(/databases/$(database)/documents/artifacts/$(appId)/clientThreads/$(threadId)) &&
        isThreadParticipant(appId, get(/databases/$(database)/documents/artifacts/$(appId)/clientThreads/$(threadId)).data);
    }

    function validPublicBookingCreate(appId, userId) {
      return request.resource.data.source == 'public-booking-page' &&
        request.resource.data.workspaceSlug is string &&
        request.resource.data.ownerId == userId &&
        request.resource.data.clientName is string &&
        request.resource.data.clientPhone is string &&
        request.resource.data.clientEmail is string &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/workspaces/$(request.resource.data.workspaceSlug)) &&
        get(/databases/$(database)/documents/artifacts/$(appId)/public/data/workspaces/$(request.resource.data.workspaceSlug)).data.ownerId == userId;
    }

    match /artifacts/{appId}/accounts/{accountId} {
      allow read, create, update: if signedIn() && request.auth.uid == accountId;
      allow delete: if false;
    }

    match /artifacts/{appId}/accountLookup/{email} {
      allow read: if signedIn();
      allow create, update: if signedIn() &&
        request.auth.token.email == email &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == email;
      allow delete: if false;
    }

    match /artifacts/{appId}/staffAccess/{email}/workspaces/{ownerId} {
      allow read: if signedIn() && (request.auth.token.email == email || canAdmin(appId, ownerId));
      allow create, update: if canAdmin(appId, ownerId) &&
        request.resource.data.ownerId == ownerId &&
        request.resource.data.email == email &&
        request.resource.data.status in ['active', 'revoked'] &&
        request.resource.data.role in ['staff', 'admin'];
      allow delete: if canAdmin(appId, ownerId);
    }

    match /artifacts/{appId}/users/{userId}/config/{docId} {
      allow read: if canStaff(appId, userId);
      allow write: if docId == 'clients'
        ? canStaff(appId, userId)
        : canAdmin(appId, userId);
    }

    match /artifacts/{appId}/users/{userId}/bookings/{bookingId} {
      allow read, update, delete: if canStaff(appId, userId);
      allow create: if canStaff(appId, userId) || validPublicBookingCreate(appId, userId);
    }

    match /artifacts/{appId}/clientAccess/{email}/bookings/{bookingId} {
      allow read: if signedIn() &&
        (request.auth.token.email == email || (resource.data.ownerId is string && canStaff(appId, resource.data.ownerId)));
      allow create, update: if signedIn() &&
        request.resource.data.ownerId is string &&
        canStaff(appId, request.resource.data.ownerId) &&
        request.resource.data.clientEmail == email;
      allow delete: if false;
    }

    match /artifacts/{appId}/clientThreads/{threadId} {
      allow read: if isThreadParticipant(appId, resource.data);
      allow create: if signedIn() &&
        request.resource.data.ownerId is string &&
        (
          canStaff(appId, request.resource.data.ownerId) ||
          (request.auth.token.email != null && request.resource.data.clientEmail == request.auth.token.email)
        );
      allow update: if isThreadParticipant(appId, resource.data) &&
        request.resource.data.ownerId == resource.data.ownerId &&
        request.resource.data.clientEmail == resource.data.clientEmail;
      allow delete: if canAdmin(appId, resource.data.ownerId);

      match /messages/{messageId} {
        allow read, create: if canAccessThread(appId, threadId);
        allow update, delete: if false;
      }
    }

    match /artifacts/{appId}/public/data/workspaces/{slug} {
      allow read: if true;
      allow create, update: if signedIn() &&
        request.resource.data.ownerId is string &&
        canAdmin(appId, request.resource.data.ownerId);
      allow delete: if signedIn() &&
        resource.data.ownerId is string &&
        canAdmin(appId, resource.data.ownerId);

      match /bookingSubmissions/{bookingId} {
        allow create: if request.resource.data.source == 'public-booking-page' &&
          request.resource.data.workspaceSlug == slug &&
          exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/workspaces/$(slug)) &&
          request.resource.data.ownerId == get(/databases/$(database)/documents/artifacts/$(appId)/public/data/workspaces/$(slug)).data.ownerId;
        allow read, update, delete: if false;
      }

      match /slotLocks/{lockId} {
        allow read, write: if false;
      }
    }

    match /artifacts/{appId}/notificationJobs/{jobId} {
      allow read: if signedIn() &&
        resource.data.ownerId is string &&
        canStaff(appId, resource.data.ownerId);
      allow create, update, delete: if false;
    }

    match /artifacts/{appId}/billing/{ownerId}/{document=**} {
      allow read: if canAdmin(appId, ownerId);
      allow write: if false;
    }
  }
}
